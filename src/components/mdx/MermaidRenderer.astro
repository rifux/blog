<script>
  const selector = '[data-mermaid-diagram] .mermaid';
  const sources = new WeakMap();
  let mermaidModule;
  let renderVersion = 0;

  const getTheme = () =>
    document.documentElement.classList.contains('dark') ||
    window.matchMedia?.('(prefers-color-scheme: dark)').matches
      ? 'dark'
      : 'default';

  const prepareNodes = () =>
    Array.from(document.querySelectorAll(selector)).map((node) => {
      const source = sources.get(node) ?? node.textContent ?? '';
      sources.set(node, source);
      node.textContent = source;
      node.removeAttribute('data-processed');
      return node;
    });

  const renderMermaid = async () => {
    const nodes = prepareNodes();
    if (!nodes.length) return;

    mermaidModule ??= (await import('mermaid')).default;

    const currentVersion = ++renderVersion;
    mermaidModule.initialize({
      startOnLoad: false,
      securityLevel: 'strict',
      theme: getTheme(),
      fontFamily: getComputedStyle(document.documentElement)
        .getPropertyValue('--font-article')
        .trim(),
    });

    try {
      await mermaidModule.run({ nodes });
    } catch (error) {
      if (currentVersion === renderVersion) {
        console.error('Unable to render Mermaid diagram.', error);
      }
    }
  };

  const scheduleRender = () => {
    window.requestAnimationFrame(() => {
      void renderMermaid();
    });
  };

  document.addEventListener('astro:page-load', scheduleRender);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', scheduleRender, { once: true });
  } else {
    scheduleRender();
  }

  new MutationObserver(scheduleRender).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['class'],
  });
</script>
